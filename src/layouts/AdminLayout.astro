---
import '../styles/global.css';
interface Props {
  title: string;
  user?: any;
}
const { title, user } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Harmony Threads Admin</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body style="margin:0; background:#0f0f0f; color:#faf7f2; font-family: var(--font-body);">
    <div style="display: flex; min-height: 100vh;">
      <!-- Sidebar -->
      <aside style="width: 220px; background: #111; border-right: 1px solid rgba(250,247,242,0.06); padding: 1.5rem; flex-shrink: 0; position: fixed; top: 0; bottom: 0; overflow-y: auto;">
        <a href="/" style="display: block; font-family: var(--font-display); font-weight: 900; font-size: 1rem; margin-bottom: 2rem; color: #faf7f2;">
          Harmony<span style="color: var(--brand-accent);">Threads</span>
        </a>
        <nav style="display: flex; flex-direction: column; gap: 0.25rem;">
          {[
            { href: '/admin', label: 'Dashboard' },
            { href: '/admin/products', label: 'Products' },
            { href: '/admin/orders', label: 'Orders' },
            { href: '/admin/messages', label: 'Messages' },
            { href: '/admin/categories', label: 'Categories' },
          ].map(({ href, label }) => (
            <a href={href} style={`display: block; padding: 0.5rem 0.75rem; border-radius: 2px; font-size: 0.875rem; font-weight: 500; transition: background 0.15s; text-decoration: none; color: ${currentPath === href ? '#E63946' : 'rgba(250,247,242,0.7)'}; background: ${currentPath === href ? 'rgba(230,57,70,0.1)' : 'transparent'};`}>
              {label}
            </a>
          ))}
        </nav>
        <div style="margin-top: auto; padding-top: 2rem;">
          <a href="/" style="display: block; font-size: 0.8rem; color: rgba(250,247,242,0.4); margin-bottom: 0.5rem; text-decoration: none; hover: color: var(--brand-accent);">← Back to site</a>
          <form action="/api/auth/logout" method="POST">
            <button type="submit" style="background: none; border: 1px solid rgba(250,247,242,0.15); color: rgba(250,247,242,0.5); font-size: 0.8rem; padding: 0.4rem 0.8rem; border-radius: 2px; cursor: pointer; width: 100%;">Sign out</button>
          </form>
        </div>
      </aside>

      <!-- Main -->
      <main style="margin-left: 220px; flex: 1; padding: 2rem;">
        <div style="max-width: 1100px;">
          <h1 style="font-family: var(--font-display); font-size: 1.8rem; font-weight: 700; margin-bottom: 2rem;">{title}</h1>
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
