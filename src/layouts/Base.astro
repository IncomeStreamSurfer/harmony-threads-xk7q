---
import SEOHead from '../components/SEOHead.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  author?: string;
  publishDate?: string;
  modifiedDate?: string;
  tags?: string[];
  structuredData?: object | object[];
  noindex?: boolean;
}

const props = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead {...props} />
  </head>
  <body>
    <header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
      <div class="container">
        <nav class="flex items-center justify-between py-5">
          <a href="/" class="font-display text-xl font-bold tracking-tight" style="font-family: var(--font-display);">
            Harmony<span style="color: var(--brand-accent);">Threads</span>
          </a>
          <div class="hidden md:flex items-center gap-8">
            <a href="/shop" class={`text-sm font-medium transition-colors hover:text-[#E63946] ${currentPath.startsWith('/shop') ? 'text-[#E63946]' : 'text-[#faf7f2]/80'}`}>Shop</a>
            <a href="/collections/graphic-shirts" class={`text-sm font-medium transition-colors hover:text-[#E63946] ${currentPath.startsWith('/collections') ? 'text-[#E63946]' : 'text-[#faf7f2]/80'}`}>Collections</a>
            <a href="/about" class={`text-sm font-medium transition-colors hover:text-[#E63946] ${currentPath === '/about' ? 'text-[#E63946]' : 'text-[#faf7f2]/80'}`}>Our Story</a>
            <a href="/contact" class={`text-sm font-medium transition-colors hover:text-[#E63946] ${currentPath === '/contact' ? 'text-[#E63946]' : 'text-[#faf7f2]/80'}`}>Contact</a>
          </div>
          <div class="flex items-center gap-4">
            <a href="/shop" class="btn-primary text-sm py-2 px-4">Shop Now</a>
            <button id="mobile-menu-btn" class="md:hidden text-[#faf7f2]" aria-label="Open menu">
              <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </button>
          </div>
        </nav>
      </div>
      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-white/10" style="background: #0f0f0f;">
        <div class="container py-6 flex flex-col gap-4">
          <a href="/shop" class="text-sm font-medium text-[#faf7f2]/80 hover:text-[#E63946]">Shop</a>
          <a href="/collections/graphic-shirts" class="text-sm font-medium text-[#faf7f2]/80 hover:text-[#E63946]">Collections</a>
          <a href="/about" class="text-sm font-medium text-[#faf7f2]/80 hover:text-[#E63946]">Our Story</a>
          <a href="/contact" class="text-sm font-medium text-[#faf7f2]/80 hover:text-[#E63946]">Contact</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer style="background: #111; border-top: 1px solid rgba(250,247,242,0.08);">
      <div class="container py-16">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
          <div class="md:col-span-2">
            <a href="/" class="font-display text-2xl font-bold" style="font-family: var(--font-display);">
              Harmony<span style="color: var(--brand-accent);">Threads</span>
            </a>
            <p class="mt-4 text-sm leading-relaxed" style="color: rgba(250,247,242,0.5); max-width: 320px;">
              Music-inspired apparel and media for people who live the soundtrack. Rock band tees, rare digital books, and curated scents — shipped from Harmony Threads since 2024.
            </p>
          </div>
          <div>
            <h4 class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: rgba(250,247,242,0.4);">Shop</h4>
            <ul class="space-y-2 text-sm" style="color: rgba(250,247,242,0.6);">
              <li><a href="/collections/graphic-shirts" class="hover:text-[#E63946] transition-colors">Graphic Shirts</a></li>
              <li><a href="/collections/digital-books" class="hover:text-[#E63946] transition-colors">Digital Books</a></li>
              <li><a href="/collections/accessories" class="hover:text-[#E63946] transition-colors">Accessories</a></li>
              <li><a href="/shop" class="hover:text-[#E63946] transition-colors">All Products</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: rgba(250,247,242,0.4);">Company</h4>
            <ul class="space-y-2 text-sm" style="color: rgba(250,247,242,0.6);">
              <li><a href="/about" class="hover:text-[#E63946] transition-colors">Our Story</a></li>
              <li><a href="/contact" class="hover:text-[#E63946] transition-colors">Contact</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-12 pt-8 flex flex-col md:flex-row items-center justify-between gap-4" style="border-top: 1px solid rgba(250,247,242,0.08);">
          <p class="text-xs" style="color: rgba(250,247,242,0.3);">© 2026 Harmony Threads. All rights reserved.</p>
          <p class="text-xs" style="color: rgba(250,247,242,0.3);">Powered by music &amp; good taste.</p>
        </div>
      </div>
    </footer>

    <script>
      // Sticky header
      const header = document.getElementById('site-header');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 60) {
          header?.classList.add('scrolled');
          header?.style.setProperty('background', 'rgba(15,15,15,0.95)');
          header?.style.setProperty('backdrop-filter', 'blur(12px)');
          header?.style.setProperty('border-bottom', '1px solid rgba(250,247,242,0.08)');
        } else {
          header?.style.setProperty('background', 'transparent');
          header?.style.setProperty('backdrop-filter', 'none');
          header?.style.setProperty('border-bottom', 'none');
        }
      });

      // Mobile menu
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
