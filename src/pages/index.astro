---
import Base from '../layouts/Base.astro';

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Harmony Threads",
  "url": import.meta.env.PUBLIC_SITE_URL || "https://harmony-threads-xk7q.vercel.app",
  "logo": `${import.meta.env.PUBLIC_SITE_URL || "https://harmony-threads-xk7q.vercel.app"}/favicon.svg`,
  "sameAs": []
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Harmony Threads",
  "url": import.meta.env.PUBLIC_SITE_URL || "https://harmony-threads-xk7q.vercel.app",
  "description": "Music-inspired apparel and media. Graphic tees, digital books, and curated scents for people who live the soundtrack."
};
---

<Base
  title="Harmony Threads | Music-Inspired Apparel & Merch"
  description="Rock band graphic tees, digital music books, and curated accessories. Shop the collection at Harmony Threads — where music meets style."
  structuredData={[orgSchema, websiteSchema]}
>
  <!-- HERO -->
  <section style="min-height: 100vh; background: #0f0f0f; position: relative; overflow: hidden; display: flex; align-items: center;">
    <!-- Background texture -->
    <div style="position: absolute; inset: 0; background: radial-gradient(ellipse at 70% 50%, rgba(230,57,70,0.08) 0%, transparent 60%);"></div>
    <!-- Large decorative text -->
    <div style="position: absolute; right: -2rem; top: 50%; transform: translateY(-50%); font-family: var(--font-display); font-size: clamp(8rem, 20vw, 18rem); font-weight: 900; color: rgba(250,247,242,0.03); line-height: 1; pointer-events: none; white-space: nowrap; letter-spacing: -0.04em;">MUSIC</div>

    <div class="container" style="position: relative; z-index: 1; padding-top: 8rem; padding-bottom: 6rem;">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-xs font-semibold tracking-widest uppercase mb-6" style="color: var(--brand-accent);">New arrivals · Spring 2026</p>
          <h1 style="font-family: var(--font-display); font-size: clamp(3rem, 6vw, 5.5rem); font-weight: 900; line-height: 0.95; letter-spacing: -0.03em; color: var(--brand-paper); margin: 0 0 1.5rem;">
            Wear the music.<br />
            <em style="font-style: italic; color: var(--brand-accent);">Own the story.</em>
          </h1>
          <p style="font-size: 1.1rem; line-height: 1.7; color: rgba(250,247,242,0.6); max-width: 420px; margin-bottom: 2.5rem;">
            Graphic tees that carry the weight of rock history. Digital books that trace the riffs. Scents that smell like a backstage pass. Three collections, one obsession.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/shop" class="btn-primary">Shop the Collection</a>
            <a href="/about" class="btn-ghost">Our Story</a>
          </div>
          <div class="mt-12 flex items-center gap-8">
            <div>
              <p style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--brand-paper);">3</p>
              <p class="text-xs" style="color: rgba(250,247,242,0.4);">Collections</p>
            </div>
            <div style="width: 1px; height: 40px; background: rgba(250,247,242,0.15);"></div>
            <div>
              <p style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--brand-paper);">140+</p>
              <p class="text-xs" style="color: rgba(250,247,242,0.4);">Units in stock</p>
            </div>
            <div style="width: 1px; height: 40px; background: rgba(250,247,242,0.15);"></div>
            <div>
              <p style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--brand-paper);">$9.99</p>
              <p class="text-xs" style="color: rgba(250,247,242,0.4);">Starting from</p>
            </div>
          </div>
        </div>
        <div style="position: relative;">
          <!-- Product image showcase -->
          <div style="position: relative; aspect-ratio: 3/4; max-width: 420px; margin: 0 auto;">
            <div style="position: absolute; inset: 0; border-radius: 2px; overflow: hidden;">
              <img 
                src="https://burst.shopifycdn.com/photos/forest-hiker.jpg?width=1000" 
                alt="The Band graphic t-shirt — rock music tribute tee in green, gray, and red"
                style="width: 100%; height: 100%; object-fit: cover;"
                loading="eager"
              />
              <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(15,15,15,0.6) 0%, transparent 50%);"></div>
            </div>
            <div style="position: absolute; bottom: 1.5rem; left: 1.5rem; right: 1.5rem;">
              <p class="text-xs font-semibold tracking-widest uppercase mb-1" style="color: rgba(250,247,242,0.6);">Featured</p>
              <p style="font-family: var(--font-display); font-size: 1.3rem; font-weight: 700; color: var(--brand-paper);">"The Band" Graphic Tee</p>
              <div class="flex items-center justify-between mt-2">
                <p style="color: var(--brand-accent); font-weight: 700;">$19.99</p>
                <a href="/product/physical-product-the-band-t-shirt" class="text-xs font-semibold" style="color: var(--brand-paper); text-decoration: underline;">View →</a>
              </div>
            </div>
            <!-- Floating badge -->
            <div style="position: absolute; top: 1.5rem; right: 1.5rem; background: var(--brand-accent); padding: 0.4rem 0.8rem; border-radius: 2px;">
              <p class="text-xs font-bold" style="color: #fff;">Top Seller</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CATEGORIES STRIP -->
  <section style="background: #111; border-top: 1px solid rgba(250,247,242,0.06); border-bottom: 1px solid rgba(250,247,242,0.06);">
    <div class="container py-6">
      <div class="flex flex-wrap items-center gap-6 md:gap-12">
        <p class="text-xs font-semibold tracking-widest uppercase" style="color: rgba(250,247,242,0.3);">Browse by category</p>
        <a href="/collections/graphic-shirts" class="text-sm font-medium transition-colors hover:text-[#E63946]" style="color: rgba(250,247,242,0.7);">Graphic Shirts</a>
        <a href="/collections/digital-books" class="text-sm font-medium transition-colors hover:text-[#E63946]" style="color: rgba(250,247,242,0.7);">Digital Books</a>
        <a href="/collections/accessories" class="text-sm font-medium transition-colors hover:text-[#E63946]" style="color: rgba(250,247,242,0.7);">Accessories</a>
        <a href="/tags/vintage" class="text-sm font-medium transition-colors hover:text-[#E63946]" style="color: rgba(250,247,242,0.7);">#vintage</a>
        <a href="/tags/rock-music" class="text-sm font-medium transition-colors hover:text-[#E63946]" style="color: rgba(250,247,242,0.7);">#rock-music</a>
      </div>
    </div>
  </section>

  <!-- FEATURED PRODUCTS -->
  <section style="background: #0f0f0f; padding: 6rem 0;">
    <div class="container">
      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: var(--brand-accent);">The catalogue</p>
          <h2 style="font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 900; line-height: 0.95; letter-spacing: -0.02em;">Everything in the shop</h2>
        </div>
        <a href="/shop" class="hidden md:inline-flex text-sm font-semibold items-center gap-2 hover:text-[#E63946] transition-colors" style="color: rgba(250,247,242,0.6);">
          View all <span>→</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Product: The Band T-Shirt -->
        <a href="/product/physical-product-the-band-t-shirt" class="group block" style="border: 1px solid rgba(250,247,242,0.08); border-radius: 2px; overflow: hidden; transition: border-color 0.2s, transform 0.2s;" onmouseover="this.style.borderColor='rgba(230,57,70,0.4)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(250,247,242,0.08)';this.style.transform='translateY(0)'">
          <div style="aspect-ratio: 4/3; overflow: hidden;">
            <img 
              src="https://burst.shopifycdn.com/photos/forest-hiker.jpg?width=1000" 
              alt="The Band graphic t-shirt in forest green"
              style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s;"
              onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform='scale(1)'"
            />
          </div>
          <div style="padding: 1.5rem;">
            <p class="text-xs font-semibold tracking-widest uppercase mb-2" style="color: rgba(250,247,242,0.35);">Harmony Threads · Graphic Shirt</p>
            <h3 style="font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem;">"The Band" Graphic T-Shirt</h3>
            <p class="text-sm leading-relaxed mb-4" style="color: rgba(250,247,242,0.55);">Celebrate the timeless legacy of rock's most influential group. Available in 3 colors and 4 sizes.</p>
            <div class="flex items-center justify-between">
              <div>
                <span style="font-size: 1.2rem; font-weight: 700; color: var(--brand-paper);">$19.99</span>
                <span class="text-sm ml-2" style="color: rgba(250,247,242,0.3); text-decoration: line-through;">$24.99</span>
              </div>
              <span class="text-xs font-semibold" style="color: var(--brand-accent);">12 variants →</span>
            </div>
          </div>
        </a>

        <!-- Product: Digital Book -->
        <a href="/product/digital-product-the-history-of-rock-music" class="group block" style="border: 1px solid rgba(250,247,242,0.08); border-radius: 2px; overflow: hidden; transition: border-color 0.2s, transform 0.2s;" onmouseover="this.style.borderColor='rgba(230,57,70,0.4)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(250,247,242,0.08)';this.style.transform='translateY(0)'">
          <div style="aspect-ratio: 4/3; overflow: hidden; background: #1a1a1a; display: flex; align-items: center; justify-content: center;">
            <img 
              src="https://burst.shopifycdn.com/photos/forest-hiker.jpg?width=1000" 
              alt="The History of Rock Music — digital book cover"
              style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; opacity: 0.7;"
              onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform='scale(1)'"
            />
            <div style="position: absolute; top: 1rem; left: 1rem; background: #111; padding: 0.3rem 0.7rem; border-radius: 2px; border: 1px solid rgba(250,247,242,0.15);">
              <p class="text-xs font-semibold" style="color: rgba(250,247,242,0.7);">Digital</p>
            </div>
          </div>
          <div style="padding: 1.5rem;">
            <p class="text-xs font-semibold tracking-widest uppercase mb-2" style="color: rgba(250,247,242,0.35);">Harmony Publishing · eBook</p>
            <h3 style="font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem;">The History of Rock Music</h3>
            <p class="text-sm leading-relaxed mb-4" style="color: rgba(250,247,242,0.55);">From the Delta to stadium rock. Available as PDF, audiobook, and Kindle edition.</p>
            <div class="flex items-center justify-between">
              <span style="font-size: 1.2rem; font-weight: 700; color: var(--brand-paper);">from $9.99</span>
              <span class="text-xs font-semibold" style="color: var(--brand-accent);">3 formats →</span>
            </div>
          </div>
        </a>

        <!-- Product: Perfume -->
        <a href="/product/example-perfume" class="group block" style="border: 1px solid rgba(250,247,242,0.08); border-radius: 2px; overflow: hidden; transition: border-color 0.2s, transform 0.2s;" onmouseover="this.style.borderColor='rgba(230,57,70,0.4)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(250,247,242,0.08)';this.style.transform='translateY(0)'">
          <div style="aspect-ratio: 4/3; overflow: hidden;">
            <img 
              src="https://burst.shopifycdn.com/photos/black-glass-perfume-bottle-and-spritzer.jpg?width=500" 
              alt="Example Perfume — premium black glass bottle"
              style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s;"
              onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform='scale(1)'"
            />
          </div>
          <div style="padding: 1.5rem;">
            <p class="text-xs font-semibold tracking-widest uppercase mb-2" style="color: rgba(250,247,242,0.35);">Acme · Perfume</p>
            <h3 style="font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem;">Signature Perfume</h3>
            <p class="text-sm leading-relaxed mb-4" style="color: rgba(250,247,242,0.55);">A premium men's fragrance that smells like a backstage pass. Smoky, clean, unforgettable.</p>
            <div class="flex items-center justify-between">
              <span style="font-size: 1.2rem; font-weight: 700; color: var(--brand-paper);">$74.99</span>
              <span class="text-xs font-semibold" style="color: var(--brand-accent);">Shop →</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- BRAND STORY STRIP -->
  <section style="background: var(--brand-accent); padding: 5rem 0;">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: rgba(255,255,255,0.7);">Why we started this</p>
          <h2 style="font-family: var(--font-display); font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 900; line-height: 1.0; letter-spacing: -0.02em; color: #fff; margin-bottom: 1.5rem;">
            Music deserves more than a playlist.
          </h2>
          <p style="font-size: 1rem; line-height: 1.8; color: rgba(255,255,255,0.8); margin-bottom: 2rem;">
            Harmony Threads started as a passion project — finding the intersection between the bands that changed culture and the clothes worth wearing twice. Every product here was chosen because it carries weight.
          </p>
          <a href="/about" class="inline-flex items-center gap-2 text-sm font-semibold" style="color: #fff; text-decoration: underline; text-underline-offset: 4px;">
            Read our story →
          </a>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div style="background: rgba(0,0,0,0.2); padding: 1.5rem; border-radius: 2px;">
            <p style="font-family: var(--font-display); font-size: 2.5rem; font-weight: 900; color: #fff;">3</p>
            <p class="text-sm" style="color: rgba(255,255,255,0.7);">Distinct product categories</p>
          </div>
          <div style="background: rgba(0,0,0,0.2); padding: 1.5rem; border-radius: 2px;">
            <p style="font-family: var(--font-display); font-size: 2.5rem; font-weight: 900; color: #fff;">12</p>
            <p class="text-sm" style="color: rgba(255,255,255,0.7);">T-shirt size/color variants</p>
          </div>
          <div style="background: rgba(0,0,0,0.2); padding: 1.5rem; border-radius: 2px;">
            <p style="font-family: var(--font-display); font-size: 2.5rem; font-weight: 900; color: #fff;">100%</p>
            <p class="text-sm" style="color: rgba(255,255,255,0.7);">Passion-curated catalogue</p>
          </div>
          <div style="background: rgba(0,0,0,0.2); padding: 1.5rem; border-radius: 2px;">
            <p style="font-family: var(--font-display); font-size: 2.5rem; font-weight: 900; color: #fff;">2026</p>
            <p class="text-sm" style="color: rgba(255,255,255,0.7);">Spring season live now</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section style="background: #111; padding: 5rem 0; border-top: 1px solid rgba(250,247,242,0.06);">
    <div class="container">
      <div style="max-width: 560px; margin: 0 auto; text-align: center;">
        <p class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: var(--brand-accent);">Join the list</p>
        <h2 style="font-family: var(--font-display); font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 900; line-height: 1.0; letter-spacing: -0.02em; margin-bottom: 1rem;">
          New drops. No spam.
        </h2>
        <p class="text-sm leading-relaxed mb-8" style="color: rgba(250,247,242,0.55);">
          Be first to hear about new band tees, limited editions, and music media. We send maybe four emails a year.
        </p>
        <form action="/api/subscribe" method="POST" id="newsletter-form" style="display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content: center;">
          <!-- Honeypot -->
          <input type="text" name="website" style="display:none" tabindex="-1" autocomplete="off" />
          <input type="hidden" name="rendered_at" id="rendered_at" />
          <input 
            type="email" 
            name="email" 
            placeholder="your@email.com" 
            required
            style="flex: 1; min-width: 220px; background: rgba(250,247,242,0.05); border: 1px solid rgba(250,247,242,0.15); padding: 0.75rem 1rem; border-radius: 2px; color: var(--brand-paper); font-family: var(--font-body); font-size: 0.9rem; outline: none;"
          />
          <button type="submit" class="btn-primary">Join the list</button>
        </form>
        <div id="subscribe-msg" class="mt-4 text-sm" style="color: rgba(250,247,242,0.6); display: none;"></div>
      </div>
    </div>
    <script>
      document.getElementById('rendered_at')!.value = Date.now().toString();
      document.getElementById('newsletter-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target as HTMLFormElement;
        const msg = document.getElementById('subscribe-msg')!;
        const res = await fetch('/api/subscribe', { method: 'POST', body: new FormData(form) });
        msg.style.display = 'block';
        if (res.ok) {
          msg.textContent = "You're on the list. Welcome to the band.";
          msg.style.color = '#4ade80';
          form.reset();
        } else {
          msg.textContent = 'Something went wrong. Try again.';
          msg.style.color = '#f87171';
        }
      });
    </script>
  </section>
</Base>
