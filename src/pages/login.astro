---
import Base from '../layouts/Base.astro';

export const prerender = false;

const next = Astro.url.searchParams.get("next") ?? "/admin";
const sent = Astro.url.searchParams.get("sent");
const sentEmail = Astro.url.searchParams.get("email");
const error = Astro.url.searchParams.get("error");
---

<Base title="Sign In | Harmony Threads" description="Sign in to manage your Harmony Threads store." noindex={true}>
  <div style="padding-top: 8rem; padding-bottom: 6rem; min-height: 100vh; background: #0f0f0f; display: flex; align-items: center; justify-content: center;">
    <div style="width: 100%; max-width: 400px; padding: 0 1.5rem;">
      <div style="background: #111; border: 1px solid rgba(250,247,242,0.08); border-radius: 2px; padding: 2.5rem;">
        <h1 style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; margin-bottom: 0.5rem;">Sign in</h1>
        
        {sent ? (
          <div>
            <div style="background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); padding: 1rem; border-radius: 2px; margin-bottom: 1.5rem;">
              <p style="font-size: 0.875rem; color: #4ade80;">
                Link sent to <strong>{sentEmail}</strong>. Check your inbox.
              </p>
            </div>
            <p style="font-size: 0.8rem; color: rgba(250,247,242,0.4);">Didn't receive it? Check your spam folder, or <a href="/login" style="color: var(--brand-accent);">try again</a>.</p>
          </div>
        ) : (
          <>
            <p style="color: rgba(250,247,242,0.6); font-size: 0.9rem; margin-bottom: 2rem;">We'll email you a sign-in link — no password needed.</p>
            {error && (
              <div style="background: rgba(230,57,70,0.1); border: 1px solid rgba(230,57,70,0.3); padding: 0.75rem 1rem; border-radius: 2px; margin-bottom: 1.5rem;">
                <p style="font-size: 0.875rem; color: #fca5a5;">Something went wrong. Please try again.</p>
              </div>
            )}
            <form method="POST" action="/api/auth/login" style="display: flex; flex-direction: column; gap: 1rem;">
              <input type="hidden" name="next" value={next} />
              <div>
                <label style="display: block; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: rgba(250,247,242,0.5); margin-bottom: 0.4rem;">Email address</label>
                <input type="email" name="email" required placeholder="you@example.com" style="width: 100%; background: rgba(250,247,242,0.04); border: 1px solid rgba(250,247,242,0.12); padding: 0.75rem 1rem; border-radius: 2px; color: #faf7f2; font-size: 0.9rem; font-family: var(--font-body);" />
              </div>
              <button type="submit" class="btn-primary w-full justify-center py-3">Email me a link</button>
            </form>
          </>
        )}
      </div>
    </div>
  </div>
</Base>
