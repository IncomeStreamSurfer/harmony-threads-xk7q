---
import Base from '../../layouts/Base.astro';
import { stripe } from '../../lib/stripe';

export const prerender = false;

const sessionId = Astro.url.searchParams.get('session_id');
let session: any = null;

if (sessionId) {
  try {
    session = await stripe().checkout.sessions.retrieve(sessionId, {
      expand: ['line_items'],
    });
  } catch (e) {
    // silently fail
  }
}
---

<Base
  title="Order Confirmed | Harmony Threads"
  description="Your Harmony Threads order has been confirmed."
  noindex={true}
>
  <div style="padding-top: 8rem; padding-bottom: 6rem; min-height: 100vh; background: #0f0f0f;">
    <div class="container" style="max-width: 640px;">
      <div style="text-align: center; margin-bottom: 3rem;">
        <div style="width: 64px; height: 64px; border-radius: 50%; background: rgba(34,197,94,0.1); border: 2px solid #22c55e; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
        </div>
        <h1 style="font-family: var(--font-display); font-size: 2.5rem; font-weight: 900; margin-bottom: 0.75rem;">Order confirmed</h1>
        <p style="color: rgba(250,247,242,0.6);">Thanks for shopping at Harmony Threads. {session?.customer_details?.email ? `A confirmation has been sent to ${session.customer_details.email}.` : 'Check your email for confirmation.'}</p>
      </div>

      {session && (
        <div style="border: 1px solid rgba(250,247,242,0.1); border-radius: 2px; padding: 2rem; margin-bottom: 2rem;">
          <p class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: rgba(250,247,242,0.4);">Order Summary</p>
          {session.line_items?.data?.map((item: any) => (
            <div class="flex justify-between py-2" style="border-bottom: 1px solid rgba(250,247,242,0.06);">
              <span style="color: rgba(250,247,242,0.8);">{item.description} × {item.quantity}</span>
              <span>${((item.amount_total ?? 0) / 100).toFixed(2)}</span>
            </div>
          ))}
          <div class="flex justify-between pt-3 mt-2">
            <span class="font-semibold">Total</span>
            <span class="font-semibold" style="color: var(--brand-accent);">${((session.amount_total ?? 0) / 100).toFixed(2)} {(session.currency ?? 'usd').toUpperCase()}</span>
          </div>
        </div>
      )}

      <div class="flex gap-4 justify-center">
        <a href="/shop" class="btn-ghost">Continue Shopping</a>
        <a href="/" class="btn-primary">Back to Home</a>
      </div>
    </div>
  </div>
</Base>
