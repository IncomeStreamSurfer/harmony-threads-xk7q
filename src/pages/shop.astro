---
import Base from '../layouts/Base.astro';
import { anonClient } from '../lib/supabase';

const sb = anonClient();
let products: any[] = [];
if (sb) {
  const { data } = await sb
    .from('products')
    .select('id, slug, name, description, price_pence, compare_at_pence, currency, image_url, tags, vendor, product_type')
    .not('published_at', 'is', null)
    .order('created_at', { ascending: true });
  products = data ?? [];
}

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://harmony-threads-xk7q.vercel.app';

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Shop", "item": `${siteUrl}/shop` }
  ]
};
---

<Base
  title="Shop | Harmony Threads"
  description="Browse the full Harmony Threads catalogue — graphic band tees, digital music books, and curated accessories. Free shipping over $50."
  structuredData={breadcrumb}
>
  <div style="padding-top: 5rem; min-height: 100vh; background: #0f0f0f;">
    <section style="background: #111; border-bottom: 1px solid rgba(250,247,242,0.06); padding: 4rem 0 3rem;">
      <div class="container">
        <p class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: var(--brand-accent);">All products</p>
        <h1 style="font-family: var(--font-display); font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 900; line-height: 0.95; letter-spacing: -0.02em;">The Full Catalogue</h1>
        <p class="mt-4 text-sm" style="color: rgba(250,247,242,0.5);">
          {products.length} products across 3 collections — 
          <a href="/collections/graphic-shirts" style="color: var(--brand-accent);">Graphic Shirts</a> · 
          <a href="/collections/digital-books" style="color: var(--brand-accent);">Digital Books</a> · 
          <a href="/collections/accessories" style="color: var(--brand-accent);">Accessories</a>
        </p>
      </div>
    </section>

    <section style="padding: 4rem 0;">
      <div class="container">
        {products.length === 0 ? (
          <p style="color: rgba(250,247,242,0.4); text-align: center; padding: 4rem 0;">No products found.</p>
        ) : (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {products.map(p => (
              <a href={`/product/${p.slug}`} class="group block" style="border: 1px solid rgba(250,247,242,0.08); border-radius: 2px; overflow: hidden; transition: border-color 0.2s, transform 0.2s;" onmouseover="this.style.borderColor='rgba(230,57,70,0.4)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(250,247,242,0.08)';this.style.transform='translateY(0)'">
                <div style="aspect-ratio: 4/3; overflow: hidden; background: #1a1a1a;">
                  {p.image_url && (
                    <img src={p.image_url} alt={`${p.name} — Harmony Threads`} style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s;" onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform='scale(1)'" />
                  )}
                </div>
                <div style="padding: 1.5rem;">
                  <p class="text-xs font-semibold tracking-widest uppercase mb-2" style="color: rgba(250,247,242,0.35);">{p.vendor} · {p.product_type}</p>
                  <h2 style="font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; margin-bottom: 0.5rem; line-height: 1.2;">{p.name}</h2>
                  <p class="text-sm leading-relaxed mb-4" style="color: rgba(250,247,242,0.55);">{p.description?.slice(0, 100)}...</p>
                  <div class="flex items-center justify-between">
                    <div>
                      <span style="font-size: 1.1rem; font-weight: 700;">${(p.price_pence / 100).toFixed(2)}</span>
                      {p.compare_at_pence && (
                        <span class="text-sm ml-2" style="color: rgba(250,247,242,0.3); text-decoration: line-through;">${(p.compare_at_pence / 100).toFixed(2)}</span>
                      )}
                    </div>
                    <span class="text-xs font-semibold" style="color: var(--brand-accent);">View →</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>
  </div>
</Base>
